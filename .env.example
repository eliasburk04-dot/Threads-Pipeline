# Application paths and logging
APP_NAME=threads-github-bot
APP_BASE_DIR=/var/lib/threads-github-bot
APP_DATA_DIR=/var/lib/threads-github-bot
APP_LOG_DIR=/var/log/threads-github-bot
APP_DB_PATH=/var/lib/threads-github-bot/threads_github_bot.sqlite3
APP_STATUS_PATH=/var/lib/threads-github-bot/status.json
APP_LOG_LEVEL=INFO
APP_TIMEZONE=Europe/Berlin

# GitHub discovery and queueing
# GITHUB_TOKEN is optional but recommended to avoid low unauthenticated rate limits.
GITHUB_TOKEN=
GITHUB_TOPICS=ai,developer-tools,open-source,agents,llm,rag,productivity,saas,dev-infra
GITHUB_WHITELIST_TOPICS=
GITHUB_BLACKLIST_TOPICS=crypto,gambling,nft
GITHUB_BLACKLIST_REPOS=
GITHUB_WHITELIST_REPOS=
GITHUB_MIN_STARS=150
GITHUB_FETCH_LIMIT_PER_TOPIC=20
GITHUB_QUEUE_SIZE=12
GITHUB_RECENT_ACTIVITY_DAYS=45
GITHUB_MIN_DESCRIPTION_LENGTH=24
GITHUB_TIMEOUT_SECONDS=20
GITHUB_DISCOVERABILITY_STAR_FLOOR=500
GITHUB_DISCOVERABILITY_STAR_CEILING=10000

# Legacy ranking knobs retained for compatibility with the original bot.
RANK_WEIGHT_RECENCY=0.24
RANK_WEIGHT_STARS=0.20
RANK_WEIGHT_DESCRIPTION=0.18
RANK_WEIGHT_TOPICS=0.16
RANK_WEIGHT_URL=0.10
RANK_WEIGHT_ACTIVITY=0.12

# Cooldown, novelty, and diversity controls
COOLDOWN_REPO_DAYS=21
COOLDOWN_SIMILARITY_DAYS=30
COOLDOWN_TOPIC_DAYS=7
COOLDOWN_SIMILARITY_THRESHOLD=0.82
COOLDOWN_SERIES_DAYS=3
COOLDOWN_TOPIC_FAMILIES=agents=agents|coding-agents|ai-agents;rag=rag|retrieval|vector-db;llm=llm|foundation-models|language-models;local-ai=local-ai|ollama|on-device-ai

# OpenAI generation and grounding validation
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_VALIDATION_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_ENABLE_GROUNDING_VALIDATOR=true
OPENAI_TEMPERATURE=0.6
OPENAI_MAX_OUTPUT_TOKENS=800

# Content and multi-post thread defaults
CONTENT_LANGUAGE=en
CONTENT_MIN_TEXT_BYTES=120
CONTENT_MAX_TEXT_BYTES=500
THREAD_POST_COUNT_MIN=4
THREAD_POST_COUNT_MAX=6
THREAD_STRUCTURE=hook,what_it_is,standout_points,why_it_matters,repo_link

# Branded series formats
SERIES_TEMPLATES=hidden-github-gem,ai-repo-worth-trying,open-source-tool-of-the-day,dev-tool-i-didnt-know-existed,trending-ai-repo
SERIES_ENABLE_NUMBERING=true
SERIES_ALLOW_CONSECUTIVE=false
SERIES_WHITELIST=
SERIES_BLACKLIST=

# Scheduling and jitter
# The checker service wakes every 5 minutes; these values define the deterministic target slots.
SCHEDULE_MORNING_TIME=08:30
SCHEDULE_EVENING_TIME=19:30
SCHEDULE_JITTER_MINUTES=10
SCHEDULE_CHECK_GRACE_MINUTES=6
SCHEDULE_ALLOWED_WEEKDAYS=0,1,2,3,4,5,6
SCHEDULE_JITTER_SEED=threads-github-bot
SCHEDULE_ENABLE_ADAPTIVE=false
SCHEDULE_STRATEGY=windowed-jitter-v1

# Threads API publishing
# THREADS_ACCESS_TOKEN must be a valid Threads user access token with publish permissions.
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=
THREADS_API_BASE_URL=https://graph.threads.net/v1.0
THREADS_TIMEOUT_SECONDS=30
THREADS_RETRY_COUNT=3
THREADS_RETRY_BACKOFF_SECONDS=2.0
THREADS_PUBLISH_DELAY_MIN_SECONDS=15
THREADS_PUBLISH_DELAY_MAX_SECONDS=30
# Legacy fixed delay knob, retained for compatibility if min/max are unset.
# THREADS_PUBLISH_DELAY_SECONDS=30
